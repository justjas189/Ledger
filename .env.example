# Copy this file to ".env" and fill in your real PostgreSQL connection string.
#   cp .env.example .env      (macOS/Linux)
#   Copy-Item .env.example .env   (Windows PowerShell)
#
# Format:
#   postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
#
# The default below matches a standard local PostgreSQL install where you
# created a database called "expense_tracker". Change USER/PASSWORD to match
# the credentials you set when installing PostgreSQL.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/expense_tracker?schema=public"

# Monthly income used for the dashboard's balance + savings-rate metrics.
# Optional — defaults to 4500 (see server/utils/budgets.ts).
MONTHLY_INCOME=4500
