{
  "name": "vaulted",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Vaulted — a clean, light/dark FinTech expense tracker. Nuxt 3 + Prisma + PostgreSQL.",
  "scripts": {
    "dev": "nuxt dev --host",
    "build": "prisma generate && nuxt build",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@nuxtjs/supabase": "^2.0.9",
    "@prisma/client": "6.19.3",
    "lucide-vue-next": "^1.0.0",
    "nuxt": "3.21.8",
    "openai": "^6.46.0",
    "resend": "^6.17.2",
    "tesseract.js": "^7.0.0",
    "vue": "3.5.39",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@nuxt/fonts": "^0.14.0",
    "@nuxtjs/tailwindcss": "6.14.0",
    "@types/node": "^22",
    "prisma": "6.19.3",
    "tailwindcss": "3.4.19",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vue-tsc": "^2.1.10"
  }
}
